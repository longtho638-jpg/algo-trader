{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "types": ["node"],
    "isolatedModules": false,
    "typeRoots": ["./node_modules/@types"],
    "incremental": true,
    "composite": false,
    "declaration": true,
    "downlevelIteration": true,
    "lib": ["ES2023"],
    "baseUrl": ".",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "node_modules/.cache",
    "**/*.test.ts",
    "src/api/routes/monitoring-routes.ts",
    "src/api/routes/monitoring-routes-extension.ts",
    "src/workers/**/*",
    "src/strategies/polymarket/**/*",
    "src/wiring/**/*",
    "dist",
    "src/dashboard/dashboard-server.ts",
    "src/dashboard/dashboard-routes.ts",
    "src/dashboard/dashboard-middleware.ts",
    "src/dashboard/dashboard-demo-data.ts",
    "src/dashboard/dashboard-utils.ts",
    "src/landing/landing-server.ts",
    "src/polymarket/trading-pipeline.ts"
  ]
}
