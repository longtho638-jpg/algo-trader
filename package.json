{
  "name": "algo-trade",
  "version": "0.1.0",
  "type": "module",
  "description": "Algorithmic trading platform - Polymarket 80% + CEX/DEX 20%",
  "main": "src/cli/index.ts",
  "scripts": {
    "start": "npx tsx src/cli/index.ts",
    "build": "npx tsc",
    "check": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "pnpm rebuild better-sqlite3"
  },
  "dependencies": {
    "@polar-sh/sdk": "^0.46.6",
    "better-sqlite3": "11.6.0",
    "ccxt": "^4.4.0",
    "commander": "^12.0.0",
    "ethers": "^6.13.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
