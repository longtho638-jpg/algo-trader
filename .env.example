# AlgoTrade Bot — Environment Configuration
# Copy: cp .env.example .env → fill in your credentials
# NEVER commit .env to git!

# ═══════════ REQUIRED FOR TRADING ═══════════

# Polymarket CLOB API (from polymarket.com → Settings → API Keys)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ═══════════ LLM CONFIGURATION (Dual-Model) ═══════════
# Primary gateway: DeepSeek R1 (deep reasoning)
# Scanner gateway: Nemotron-3 Nano (fast inference)

OPENCLAW_GATEWAY_URL=http://localhost:11435/v1
OPENCLAW_SCANNER_URL=http://localhost:11436/v1
OPENCLAW_MODEL_SIMPLE=
OPENCLAW_MODEL_STANDARD=
OPENCLAW_MODEL_COMPLEX=
OPENCLAW_TIMEOUT_MS=300000

# Fallback LLM configuration (optional)
# LLM_PRIMARY_URL=
# LLM_PRIMARY_MODEL=
# LLM_FALLBACK_URL=
# LLM_FALLBACK_MODEL=

# ═══════════ DATA ═══════════

DATABASE_PATH=data/algo-trade.db

# ═══════════ TRADING DEFAULTS ═══════════

# Paper trading is ON by default (safe). Set to false for live execution.
PAPER_TRADING=true

# Starting capital in USDC
CAPITAL_USDC=200

# ═══════════ LICENSING (Required for RaaS mode) ═══════════

# LICENSE_KEY_PREFIX=raas
LICENSE_ACTIVATION_SECRET=your-32-byte-hex-string-for-activation
LICENSE_ENCRYPTION_KEY=your-32-byte-hex-string-for-encryption

# ═══════════ BILLING — NOWPayments (Crypto USDT TRC20) ═══════════

# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# USDT_TRC20_WALLET=
# NOWPAYMENTS_INVOICE_PRO=
# NOWPAYMENTS_INVOICE_ENTERPRISE=

# ═══════════ NOTIFICATIONS (Optional) ═══════════

# Telegram Alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email Alerts (SendGrid)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Algo Trader

# SMS Alerts (Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ═══════════ INFRASTRUCTURE (Optional) ═══════════

# NATS Message Bus (event-driven architecture)
# If set, NATS is used for pub/sub. If empty, falls back to Redis pub/sub.
# NATS_URL=nats://localhost:4222
# NATS_TOKEN=
# NATS_CLIENT_NAME=algo-trader

# Redis (for caching/queues)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Usage Metering
# USAGE_METERING_ENABLED=true
# OVERAGE_ENABLED=true
# OVERAGE_PRICE_PER_CALL=0.01

# Dunning
# DUNNING_ENABLED=true
# DUNNING_GRACE_PERIOD_DAYS=7

# Audit Logging
# AUDIT_LOG_ENABLED=true
# AUDIT_RETENTION_DAYS=90
# AUDIT_BATCH_SIZE=100
