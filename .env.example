# ═══════════════════════════════════════════════════════════════════════════════
# CashClaw — Environment Configuration
# Copy: cp .env.example .env → fill in your credentials
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════════════════

# ─── POLYMARKET CLOB API (Required for trading) ──────────────────────────────
# Get from polymarket.com → Settings → API Keys
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_PASSPHRASE=

# ─── TRADING MODE ────────────────────────────────────────────────────────────
# Paper trading (safe default). Set PAPER_TRADING=false for LIVE execution.
PAPER_TRADING=true
CAPITAL_USDC=200

# ─── LLM INFERENCE (M1 Max bare-metal mlx_lm.server) ────────────────────────
# Primary: DeepSeek R1 — deep reasoning (~10 tok/s, 90s timeout)
LLM_PRIMARY_URL=http://127.0.0.1:11435/v1
LLM_PRIMARY_MODEL=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit

# Fast triage: Nemotron Nano — quick fair value (~45 tok/s, 10s timeout)
LLM_FAST_TRIAGE_URL=http://127.0.0.1:11436/v1
LLM_FAST_TRIAGE_MODEL=mlx-community/NVIDIA-Nemotron-3-Nano-30B-A3B-4bit

# Fallback: Ollama (if MLX servers down)
LLM_FALLBACK_URL=http://127.0.0.1:11434/v1
LLM_FALLBACK_MODEL=deepseek-r1:32b

# Cloud failover: Claude API (optional, daily budget enforced)
# CLAUDE_API_KEY=sk-ant-...
# LLM_CLOUD_DAILY_BUDGET=100

# ─── ALPHAEAR INTELLIGENCE SIDECAR ──────────────────────────────────────────
# FastAPI sidecar for FinBERT sentiment + Kronos forecasting
# Runs bare metal at :8100 (needs Metal GPU for PyTorch MPS)
# See intelligence/README.md for setup
ALPHAEAR_SIDECAR_URL=http://127.0.0.1:8100

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_PATH=data/algo-trade.db
# USER_DB_PATH=data/users.db
# USAGE_DB_PATH=data/usage.db
# UTM_DB_PATH=data/utm.db
# LICENSE_DB_PATH=data/licenses.db
# REFERRAL_DB_PATH=data/referrals.db

# ─── SERVER PORTS ────────────────────────────────────────────────────────────
API_PORT=3000
DASHBOARD_PORT=3001
LANDING_PORT=3002
WS_PORT=3003
WEBHOOK_PORT=3004

# ─── AUTH & ADMIN ────────────────────────────────────────────────────────────
# JWT secret for API auth (generate: openssl rand -hex 32)
# JWT_SECRET=
# ADMIN_EMAIL=admin@cashclaw.cc
# ADMIN_PASSWORD=
# ADMIN_SECRET=

# ─── RISK MANAGEMENT ────────────────────────────────────────────────────────
# MAX_POSITION_SIZE=100
# MAX_OPEN_POSITIONS=15
# MAX_DRAWDOWN=0.15
# STOP_LOSS_PERCENT=0.10
# MAX_LEVERAGE=1
# DAILY_LOSS_LIMIT=0.05
# MAX_CONSECUTIVE_LOSSES=5
# BRIER_THRESHOLD=0.20

# ─── NOTIFICATIONS (Optional) ───────────────────────────────────────────────
# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=alerts@cashclaw.cc
# SMTP_ALERT_TO=

# ─── CEX / DEX (Optional) ───────────────────────────────────────────────────
# Binance
# BINANCE_API_KEY=
# BYBIT_API_KEY=

# Kalshi
# KALSHI_API_KEY=
# KALSHI_PRIVATE_KEY=

# Blockchain RPCs
# ETH_RPC_URL=
# POLYGON_RPC_URL=
# SOLANA_RPC_URL=

# ─── EXTERNAL DATA (Optional) ───────────────────────────────────────────────
# NEWSAPI_KEY=
# TWITTER_BEARER_TOKEN=

# ─── LICENSE (RaaS features) ────────────────────────────────────────────────
# LICENSE_KEY=
# LICENSE_SECRET=
