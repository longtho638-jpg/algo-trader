# =============================================================================
# POLAR.SH API CONFIGURATION
# =============================================================================
POLAR_API_KEY=sk_live_REPLACE_WITH_YOUR_KEY
POLAR_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET
POLAR_PRO_BENEFIT_ID=ben_pro_monthly
POLAR_ENTERPRISE_BENEFIT_ID=ben_ent_monthly

# Checkout URLs
POLAR_SUCCESS_URL=https://algo-trader.local/upgrade/success
POLAR_CANCEL_URL=https://algo-trader.local/upgrade/cancelled

# =============================================================================
# LICENSE SERVICE (RAAS)
# =============================================================================
RAAS_LICENSE_SECRET=CHANGE_ME_TO_32_CHAR_SECRET_MIN_LENGTH

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Docker: postgresql://algo_trader:algo_trader_dev@postgres:5432/algo_trader
# Local:  postgresql://user:password@localhost:5432/algo_trader?schema=public
# SQLite: file:./dev.db
DATABASE_URL="postgresql://algo_trader:algo_trader_dev@postgres:5432/algo_trader?schema=public"

# Docker Compose environment variables
POSTGRES_USER=algo_trader
POSTGRES_PASSWORD=algo_trader_dev
POSTGRES_DB=algo_trader

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# POLYMARKET — 3-Strategy Bot (CashClaw)
# =============================================================================
PRIVATE_KEY=0x_your_ethereum_private_key
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER_ADDRESS=

# =============================================================================
# KALSHI — Cross-Platform Arb
# =============================================================================
KALSHI_API_KEY_ID=your_kalshi_key_id
KALSHI_PRIVATE_KEY_PATH=./kalshi-private-key.pem
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# =============================================================================
# BINANCE — Listing Detection
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# =============================================================================
# BOT CONFIG
# =============================================================================
DRY_RUN=true
MAX_BANKROLL=5000
MAX_POSITION_PCT=0.06
MIN_ARB_EDGE=0.02
MM_SPREAD=0.10
MM_SIZE=50
HEARTBEAT_MS=5000
SCAN_INTERVAL_MS=60000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
API_PORT=3000
HEALTH_PORT=3000
METRICS_PORT=3001
LOG_LEVEL=info

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3002

# =============================================================================
# DOCKER COMPOSE PORTS
# =============================================================================
APP_PORT=3000
METRICS_PORT=3001
GRAFANA_PORT=3002

# =============================================================================
# CLOUDFLARE WORKERS AI (for local testing)
# =============================================================================
CF_ACCOUNT_ID=your_account_id
CF_API_TOKEN=your_api_token_with_ai_write_permission
# Model: @cf/meta/llama-3-8b-instruct (default), @cf/qwen/qwen-1.5-7b-chat-awq, etc.
